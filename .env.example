TELEGRAM_BOT_TOKEN=

# Groq (console.groq.com) — primary AI provider
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# OpenRouter (openrouter.ai) — fallback
OPENROUTER_API_KEY=

# Facebook cookies — base64 encoded Netscape cookies file
# Export from browser using "Get cookies.txt LOCALLY" extension on facebook.com
# Then encode: base64 -i facebook.com_cookies.txt
FACEBOOK_COOKIES_B64=

# Paths (do not change unless you know what you're doing)
DATA_DIR=/app/data
DB_PATH=/app/data/links.db
